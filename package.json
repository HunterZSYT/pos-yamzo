{
  "name": "yamzo-pos",
  "version": "0.1.0",
  "description": "Local-first Windows POS for Yamzo restaurant.",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "npm run build:electron && npm-run-all --parallel dev:renderer start:electron:dev",
    "dev:renderer": "vite --host 127.0.0.1",
    "build:electron": "tsc -p tsconfig.electron.json",
    "start:electron:dev": "wait-on tcp:5173 dist-electron/main/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "start:electron": "electron .",
    "build": "tsc --noEmit && vite build && tsc -p tsconfig.electron.json",
    "clean:release": "node scripts/clean-release.mjs",
    "package": "node scripts/package-windows.mjs",
    "dist": "node scripts/package-windows.mjs --installer",
    "smoke:packaged": "node scripts/smoke-packaged.mjs",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.1",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "googleapis": "^173.0.0",
    "lucide-react": "^1.22.0",
    "nodemailer": "^9.0.1",
    "papaparse": "^5.5.3",
    "radix-ui": "^1.6.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.1.0",
    "@types/nodemailer": "^6.4.17",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "cross-env": "^10.0.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.0.12",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3",
    "vite": "^7.0.6",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "com.yamzo.pos",
    "productName": "Yamzo POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/printer-setup",
        "to": "printer-setup"
      }
    ],
    "win": {
      "icon": "resources/icons/yamzo.ico",
      "target": [
        "nsis"
      ]
    }
  }
}
